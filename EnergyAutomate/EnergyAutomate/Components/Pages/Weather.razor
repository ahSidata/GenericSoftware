@page "/weather"

@using System.Collections.Specialized
@using BlazorBootstrap
@using EnergyAutomate.Definitions
@using EnergyAutomate.Services
@using Microsoft.AspNetCore.Components.Web

@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

@inject ApiService ApiService

<PageTitle>Weather</PageTitle>

<CardGroup Class="my-3">
    <Card Class="mb-2">
        <CardHeader>Time points</CardHeader>
        <CardBody>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>SunRise:</strong>
                </label>
                <div class="col-md-3">
                    @ApiService.CurrentState.SunRise?.ToString()
                </div>
            </div>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>SunSet:</strong>
                </label>
                <div class="col-md-3">
                    @ApiService.CurrentState.SunSet?.ToString()
                </div>
            </div>
        </CardBody>
    </Card>
    <Card Class="mb-2">
        <CardHeader>Durations</CardHeader>
        <CardBody>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>Daylight duration:</strong>
                </label>
                <div class="col-md-3">
                    @if (WeatherForecast?.Daily?.Daylight_duration != null)
                    {
                        var seconds = Math.Round(WeatherForecast.Daily.Daylight_duration[0], 0);
                        var sunshine_duration = TimeSpan.FromSeconds(Convert.ToInt64(seconds));
                        @($"{sunshine_duration.ToString()} (hh:mm:ss)")
                    }
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>Sunshine duration:</strong>
                </label>
                <div class="col-md-3">
                    @if (WeatherForecast?.Daily?.Sunshine_duration != null)
                    {
                        var seconds = Math.Round(WeatherForecast.Daily.Sunshine_duration[0], 0);
                        var sunshine_duration = TimeSpan.FromSeconds(Convert.ToInt64(seconds));
                        @($"{sunshine_duration.ToString()} (hh:mm:ss)")
                    }
                </div>
            </div>
        </CardBody>
    </Card>
    <Card Class="mb-2">
        <CardHeader>Location</CardHeader>
        <CardBody>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>Latitude:</strong>
                </label>
                <div class="col-md-3">
                    @ApiService.CurrentState.WeatherForecastToday?.Latitude
                </div>
            </div>

            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>Longitude:</strong>
                </label>
                <div class="col-md-3">
                    @ApiService.CurrentState.WeatherForecastToday?.Longitude
                </div>
            </div>
        </CardBody>
    </Card>
    <Card Class="mb-2">
        <CardHeader>BatteryChargeWindow</CardHeader>
        <CardBody>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>WindowStart:</strong>
                </label>
                <div class="col-md-3">
                    @ApiService.CurrentState.BatteryChargeEnd
                </div>
            </div>
            <div class="form-group row mb-3">
                <label class="col-md-3 col-form-label">
                    <strong>WindowEnd:</strong>
                </label>
                <div class="col-md-3">
                    @ApiService.CurrentState.BatteryChargeStart
                </div>
            </div>
        </CardBody>
    </Card>
</CardGroup>
<Card Class="my-3">
    <CardHeader>Weather forecast</CardHeader>
    <CardBody>
        <LineChart @ref="radiationChart" Class="weatherLineChart" Height="30" HeightUnit="Unit.Vh" />
        <LineChart @ref="cloudcoverChart" Class="weatherLineChart" Height="30" HeightUnit="Unit.Vh" />
    </CardBody>
</Card>