@page "/tracelog"

@implements IDisposable

@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

<h3>Trace Log</h3>
<button @onclick="DownloadLogFile">Download Logs</button>

@if (CustomLoggerProvider.LogMessagesAny)
{
    <Tabs @ref="tabsMainRef">
        @foreach (var category in LogMessageCategories)
        {
            <Tab Title="@category.Item1" Active="@category.Item2" OnClick="(args) => OnTabClick(args)">
                <Content>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Timestamp</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                if (selectedCategory == category.Item1)
                                {
                                    @foreach (var log in CustomLoggerProvider.GetLogMessages(category.Item1))
                                    {
                                        <tr>
                                            <td>@log.TS</td>
                                            <td>@log.Message</td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </Content>
            </Tab>
        }
    </Tabs>
}
else
{
    <p>No log messages available.</p>
}

@code {

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    [Inject]
    private CustomLoggerProvider CustomLoggerProvider { get; set; } = default!;

    private async Task DownloadLogFile()
    {
        // Generiere die Log-Nachrichten im gewünschten Format
        var logContent = GetLogMessagesForAI(); // Verwende die Methode aus vorherigen Beispielen

        // Rufe die JavaScript-Funktion auf, um die Datei herunterzuladen
        await JSRuntime.InvokeVoidAsync("downloadFile", "logs.txt", logContent);
    }

    private string GetLogMessagesForAI()
    {
        var logMessages = CustomLoggerProvider.GetLogMessages()
            .Select(log => $"[{log.TS}] <{log.Category}>: {log.Message}");

        return string.Join("\n", logMessages);
    }

    private List<Tuple<string, bool>> LogMessageCategories = new List<Tuple<string, bool>>();

    private Tabs tabsMainRef = default!;

    private void OnTabClick(TabEventArgs args) => selectedCategory = args.Title;

    private string selectedCategory = default!;

    protected override void OnInitialized()
    {
        CustomLoggerProvider.LogMessagesChanged += OnLogMessagesChanged;
    }

    public void Dispose()
    {
        CustomLoggerProvider.LogMessagesChanged -= OnLogMessagesChanged;
    }

    private void OnLogMessagesChanged()
    {
        var groupedCategories = CustomLoggerProvider.GetLogCategories();

        foreach (var category in groupedCategories)
        {
            if (!LogMessageCategories.Any(x => x.Item1 == category))
            {
                LogMessageCategories.Add(new Tuple<string, bool>(category, false));
            }
        }

        _ = InvokeAsync(StateHasChanged);
    }
}
