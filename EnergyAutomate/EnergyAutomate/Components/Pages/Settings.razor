@page "/settings"

@using BlazorBootstrap
@using EnergyAutomate.Definitions
@using EnergyAutomate.Services.CodeFactory

@rendermode InteractiveServer

@inject ApiService ApiService

<PageTitle>Settings</PageTitle>

<div class="d-flex align-items-center gap-3 mb-3">
    <Button Color="ButtonColor.Primary" @onclick="SaveSettingsAsync">Save settings</Button>
    <Button Color="ButtonColor.Secondary" @onclick="ReloadSettingsAsync">Reload settings</Button>
    <span class="text-muted">@StatusText</span>
</div>

<Tabs>
    <Tab Title="General">
        <Content>
            <Card Class="my-3">
                <CardHeader>General</CardHeader>
                <CardBody>
                    <div class="mb-3">
                        <Switch Color="ButtonColor.Primary" @bind-Value="ApiService.IsEnabled" Label="Enable automation" />
                        <Button Color="ButtonColor.Primary" @onclick="ApiService.GrowattInvokeRefreshNoahsLastData">Refresh Noah last data</Button>                   
                    </div>

                    <div class="mb-3">
                        <div class="mb-3"><Switch @bind-Value="ApiService.ApiSettingAutoMode" Label="AutoMode" /></div>
                        <div class="mb-3"><Switch @bind-Value="ApiService.ApiSettingRestrictionMode" Label="Restriction Mode" /></div>
                        <div class="mb-3"><Switch @bind-Value="ApiService.ApiSettingBatteryPriorityMode" Label="Battery Priority Mode" /></div>
                        <div class="mb-3"><Switch @bind-Value="ApiService.ApiSettingExtentionMode" Label="Extension Mode" /></div> 
                    </div>
                </CardBody>
            </Card>
            <Card Class="my-3">
                <CardHeader>Extension Mode</CardHeader>
                <CardBody>
                    <div class="mb-3">
                        <label class="form-label">Calculation</label>
                        <select class="form-select" @bind="ApiService.ActiveCalculationTemplateKey">
                            @foreach (var template in GetTemplates("Calculation"))
                            {
                                <option value="@template.Key">@template.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Adjustment</label>
                        <select class="form-select" @bind="ApiService.ActiveAdjustmentTemplateKey">
                            @foreach (var template in GetTemplates("Adjustment"))
                            {
                                <option value="@template.Key">@template.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Distribution</label>
                        <select class="form-select" @bind="ApiService.ActiveDistributionTemplateKey">
                            @foreach (var template in GetTemplates("Distribution"))
                            {
                                <option value="@template.Key">@template.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Distribution Manager</label>
                        <select class="form-select" @bind="ApiService.ActiveDistributionManagerTemplateKey">
                            @foreach (var template in GetTemplates("DistributionManager"))
                            {
                                <option value="@template.Key">@template.DisplayName</option>
                            }
                        </select>
                    </div>
                </CardBody>
            </Card>
        </Content>
    </Tab>

    <Tab Title="Power">
        <Content>
            <Card Class="my-3">
                <CardHeader>Power Settings</CardHeader>
                <CardBody>
                    <div class="mb-3">Max Power <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingMaxPower" Min="0" Max="900" TickMarks="ApiPowerTickList" Step="25" /></div>
                    <div class="mb-3">Average Power <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingAvgPower" Min="0" Max="900" TickMarks="ApiPowerTickList" Step="25" /></div>
                    <div class="mb-3">Average Power Offset <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingAvgPowerOffset" Min="-25" Max="150" TickMarks="ApiOffsetAvgTickList" Step="5" /></div>
                    <div class="mb-3">Average Power Hysteresis <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingAvgPowerHysteresis" Min="0" Max="300" TickMarks="ApiToleranceAvgTickList" Step="10" /></div>
                    <div class="mb-3">Average Power Load Seconds <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingAvgPowerLoadSeconds" Min="0" Max="180" TickMarks="AvgPowerLoadSecondsTickList" Step="5" /></div>
                    <div class="mb-3">Power Adjustment Wait Cycles <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingPowerAdjustmentWaitCycles" Min="0" Max="5" TickMarks="ApiSettingPowerAdjustmentWaitCyclesTickList" Step="1" /></div>
                    <div class="mb-3">Power Adjustment Factor <RangeInput TValue="int" @bind-Value="ApiService.ApiSettingPowerAdjustmentFactor" Min="0" Max="100" TickMarks="ApiSettingPowerAdjustmentFactorTickList" Step="10" /></div>
                </CardBody>
            </Card>
        </Content>
    </Tab>
</Tabs>
