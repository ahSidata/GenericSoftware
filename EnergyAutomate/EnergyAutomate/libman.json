{
  "version": "3.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "library": "bootstrap@5.3.8",
      "destination": "wwwroot/lib/bootstrap/",
      "files": [
        "dist/js/**",
        "dist/css/**"
      ]
    },
    {
      "library": "bootstrap-icons@1.13.1",
      "destination": "wwwroot/lib/bootstrap-icons/"
    },
    {
      "library": "sortablejs@1.15.7",
      "destination": "wwwroot/lib/sortablejs/",
      "files": [
        "Sortable.min.js"
      ]
    },
    {
      "library": "chartjs-plugin-datalabels@2.2.0",
      "destination": "wwwroot/lib/chartjs-plugin-datalabels/",
      "files": [
        "dist/chartjs-plugin-datalabels.min.js",
      ]
    },
    {
      "library": "chart.js@4.5.1",
      "destination": "wwwroot/lib/chartjs/",
      "files": [
        "dist/chart.umd.js",
        "dist/chart.umd.js.map"
      ]
    }
  ]
}